{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whyvec.dev/schemas/whyvec-validation-report.schema.json",
  "title": "WhyVec guarded repair validation report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "analysis_id", "query_kind", "evidence_strength", "obligation", "toolchain", "sources", "commands", "differential", "sanitizer", "optimization", "benchmark", "environment", "artifacts", "artifact_path", "caveats"],
  "allOf": [
    {
      "if": { "properties": { "schema_version": { "const": "1.0.0" } } },
      "then": {
        "properties": {
          "differential": { "$ref": "#/$defs/coverage_v1" },
          "sanitizer": {
            "properties": { "covered": { "$ref": "#/$defs/coverage_v1" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.1.0" } } },
      "then": {
        "required": ["candidate_source_sha256", "command_outcomes"],
        "properties": {
          "command_outcomes": { "minItems": 13 },
          "differential": { "$ref": "#/$defs/coverage_v1_1" },
          "sanitizer": {
            "properties": { "covered": { "$ref": "#/$defs/coverage_v1_1" } }
          }
        }
      }
    },
    {
      "if": { "properties": { "schema_version": { "const": "1.2.0" } } },
      "then": {
        "required": ["candidate_source_sha256", "command_outcomes", "validation_plan"],
        "properties": {
          "differential": { "$ref": "#/$defs/coverage_v1_2" },
          "sanitizer": {
            "properties": { "covered": { "$ref": "#/$defs/coverage_v1_2" } }
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": { "enum": ["1.0.0", "1.1.0", "1.2.0"] },
    "analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
    "query_kind": { "const": "repair_validation" },
    "evidence_strength": { "const": "validated_on_covered_executions" },
    "obligation": {
      "type": "object", "additionalProperties": false,
      "required": ["analysis_id", "semantic_digest", "family"],
      "properties": {
        "analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
        "semantic_digest": { "$ref": "#/$defs/sha256" },
        "family": { "const": "bound_object_disjoint_from_modified_region" }
      }
    },
    "toolchain": {
      "type": "object", "additionalProperties": false,
      "required": ["clang", "flags"],
      "properties": {
        "clang": { "$ref": "#/$defs/tool" },
        "flags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "sources": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/source" } },
    "candidate_source_sha256": { "$ref": "#/$defs/sha256" },
    "commands": {
      "type": "array", "minItems": 4,
      "items": { "type": "array", "minItems": 1, "items": { "type": "string" } }
    },
    "command_outcomes": {
      "type": "array", "minItems": 1,
      "items": { "$ref": "#/$defs/command_outcome" }
    },
    "validation_plan": { "$ref": "#/$defs/validation_plan" },
    "differential": { "$ref": "#/$defs/coverage" },
    "sanitizer": {
      "type": "object", "additionalProperties": false,
      "required": ["clean", "covered"],
      "properties": { "clean": { "const": true }, "covered": { "$ref": "#/$defs/coverage" } }
    },
    "optimization": {
      "type": "object", "additionalProperties": false,
      "required": ["fast_path", "fallback", "fast_path_line", "fallback_line"],
      "properties": {
        "fast_path": { "const": "vectorized" },
        "fallback": { "const": "missed" },
        "fast_path_line": { "type": "integer", "minimum": 1 },
        "fallback_line": { "type": "integer", "minimum": 1 },
        "records": { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/optimization_record" } }
      }
    },
    "benchmark": {
      "type": "object", "additionalProperties": false,
      "required": ["raw", "summary"],
      "properties": { "raw": { "$ref": "#/$defs/raw_benchmark" }, "summary": { "$ref": "#/$defs/benchmark_summary" } }
    },
    "environment": {
      "type": "object", "additionalProperties": false,
      "required": ["kernel", "machine", "cpu_model", "governor", "affinity", "python"],
      "properties": {
        "kernel": { "type": "string", "minLength": 1 },
        "machine": { "type": "string", "minLength": 1 },
        "cpu_model": { "type": "string", "minLength": 1 },
        "governor": { "type": "string", "minLength": 1 },
        "affinity": { "type": "array", "items": { "type": "integer", "minimum": 0 } },
        "python": { "type": "string", "minLength": 1 }
      }
    },
    "artifacts": { "type": "array", "minItems": 7, "items": { "$ref": "#/$defs/artifact" } },
    "artifact_path": { "type": "string", "minLength": 1 },
    "caveats": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "validation_plan": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "required_checks"],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "required_checks": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["id", "property"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
              "property": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" }
            }
          }
        }
      }
    },
    "optimization_record": {
      "type": "object", "additionalProperties": false,
      "required": ["pass", "kind", "name", "function", "line", "column", "outcome", "vector_width", "interleave_count"],
      "properties": {
        "pass": { "const": "loop-vectorize" },
        "kind": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "function": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 0 },
        "outcome": { "enum": ["vectorized", "missed", "other"] },
        "vector_width": { "type": ["string", "integer", "null"] },
        "interleave_count": { "type": ["string", "integer", "null"] }
      }
    },
    "tool": {
      "type": "object", "additionalProperties": false,
      "required": ["invocation_path", "resolved_path", "binary_digest", "version"],
      "properties": {
        "invocation_path": { "type": "string", "minLength": 1 },
        "resolved_path": { "type": "string", "minLength": 1 },
        "binary_digest": { "$ref": "#/$defs/sha256" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": { "path": { "type": "string", "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[^\\\\]+$" }, "sha256": { "$ref": "#/$defs/sha256" } }
    },
    "coverage": {
      "type": "object", "additionalProperties": false,
      "required": ["executions", "fast_paths", "fallback_paths", "overflow_refusals"],
      "properties": {
        "executions": { "type": "integer", "minimum": 1 },
        "fast_paths": { "type": "integer", "minimum": 1 },
        "fallback_paths": { "type": "integer", "minimum": 1 },
        "overflow_refusals": { "type": "integer", "minimum": 0 }
      }
    },
    "coverage_v1": {
      "type": "object", "additionalProperties": false,
      "required": ["executions", "fast_paths", "fallback_paths", "overflow_refusals"],
      "properties": {
        "executions": { "const": 9 }, "fast_paths": { "const": 5 },
        "fallback_paths": { "const": 4 }, "overflow_refusals": { "const": 2 }
      }
    },
    "coverage_v1_1": {
      "type": "object", "additionalProperties": false,
      "required": ["executions", "fast_paths", "fallback_paths", "overflow_refusals"],
      "properties": {
        "executions": { "const": 11 }, "fast_paths": { "const": 7 },
        "fallback_paths": { "const": 4 }, "overflow_refusals": { "const": 2 }
      }
    },
    "coverage_v1_2": {
      "type": "object", "additionalProperties": false,
      "required": ["executions", "fast_paths", "fallback_paths", "overflow_refusals"],
      "properties": {
        "executions": { "type": "integer", "minimum": 2 },
        "fast_paths": { "type": "integer", "minimum": 1 },
        "fallback_paths": { "type": "integer", "minimum": 1 },
        "overflow_refusals": { "type": "integer", "minimum": 2 }
      }
    },
    "raw_benchmark": {
      "type": "object", "additionalProperties": false,
      "required": ["elements", "repetitions", "original_ns", "guarded_ns"],
      "properties": {
        "elements": { "type": "integer", "minimum": 1 },
        "repetitions": { "type": "integer", "minimum": 1 },
        "original_ns": { "type": "array", "minItems": 31, "maxItems": 31, "items": { "type": "integer", "minimum": 1 } },
        "guarded_ns": { "type": "array", "minItems": 31, "maxItems": 31, "items": { "type": "integer", "minimum": 1 } }
      }
    },
    "benchmark_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["classification", "original_median_ns", "original_mad_ns", "guarded_median_ns", "guarded_mad_ns", "median_ratio", "decision_rule"],
      "properties": {
        "classification": { "enum": ["measured_improvement", "noise_decline"] },
        "original_median_ns": { "type": "number", "exclusiveMinimum": 0 },
        "original_mad_ns": { "type": "number", "minimum": 0 },
        "guarded_median_ns": { "type": "number", "exclusiveMinimum": 0 },
        "guarded_mad_ns": { "type": "number", "minimum": 0 },
        "median_ratio": { "type": "number", "exclusiveMinimum": 0 },
        "decision_rule": { "type": "string", "minLength": 1 }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "sha256", "size", "media_type"],
      "properties": {
        "path": { "type": "string", "pattern": "^(checks|compiler|benchmark|environment)" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    },
    "command_outcome": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "command_index", "exit_status", "stdout_sha256", "stdout_size", "stderr_sha256", "stderr_size"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command_index": { "type": "integer", "minimum": 0 },
        "exit_status": { "const": 0 },
        "stdout_sha256": { "$ref": "#/$defs/sha256" },
        "stdout_size": { "type": "integer", "minimum": 0 },
        "stderr_sha256": { "$ref": "#/$defs/sha256" },
        "stderr_size": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
