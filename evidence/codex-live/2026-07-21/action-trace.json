0; i < initial_count; ++i) {\n+      output[i] += input[i];\n+    }\n+    return;\n+  }\n+\n+  WHYVEC_FALLBACK_PATH();\n   for (int i = 0; i < *count; ++i) {\n     output[i] += input[i];\n   }\n"
