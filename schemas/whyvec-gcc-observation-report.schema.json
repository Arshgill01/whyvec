{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whyvec.dev/schemas/whyvec-gcc-observation-report.schema.json",
  "title": "WhyVec GCC optimization observation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "analysis_id", "query_kind", "adapter",
    "evidence_strength", "repository", "source", "source_digest",
    "function", "line", "generator", "toolchain", "outcome", "comparison",
    "replay", "semantic_digest", "artifacts", "artifact_path", "caveats"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0-dev" },
    "analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
    "query_kind": { "const": "gcc_optimization_observation" },
    "adapter": { "const": "gcc" },
    "evidence_strength": { "const": "observed" },
    "repository": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "source_digest": { "$ref": "#/$defs/sha256" },
    "function": { "type": "string", "minLength": 1 },
    "line": { "type": "integer", "minimum": 1 },
    "generator": { "$ref": "#/$defs/generator" },
    "toolchain": { "$ref": "#/$defs/toolchain" },
    "outcome": { "$ref": "#/$defs/outcome" },
    "comparison": {
      "oneOf": [{ "$ref": "#/$defs/comparison" }, { "type": "null" }]
    },
    "replay": { "$ref": "#/$defs/replay" },
    "semantic_digest": { "$ref": "#/$defs/sha256" },
    "artifacts": {
      "type": "array",
      "minItems": 5,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "artifact_path": { "type": "string", "minLength": 1 },
    "caveats": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invocation_path", "resolved_path", "binary_digest", "version"],
      "properties": {
        "invocation_path": { "type": "string", "minLength": 1 },
        "resolved_path": { "type": "string", "minLength": 1 },
        "binary_digest": { "$ref": "#/$defs/sha256" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "target"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "minLength": 1 }
      }
    },
    "toolchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gcc", "gzip", "optimization", "cpu", "normalized_flags"],
      "properties": {
        "gcc": { "$ref": "#/$defs/tool" },
        "gzip": { "$ref": "#/$defs/tool" },
        "optimization": { "const": "O3" },
        "cpu": { "type": "string", "minLength": 1 },
        "normalized_flags": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string" }
        }
      }
    },
    "remark": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "pass", "message", "function", "file", "line", "column"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "pass": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "function": { "type": "string", "minLength": 1 },
        "file": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "column": { "type": "integer", "minimum": 0 }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "selected_remarks", "exit_code", "timed_out", "output_truncated"],
      "properties": {
        "classification": { "enum": ["vectorized", "missed", "not_observed"] },
        "selected_remarks": {
          "type": "array",
          "items": { "$ref": "#/$defs/remark" }
        },
        "exit_code": { "type": ["integer", "null"] },
        "timed_out": { "type": "boolean" },
        "output_truncated": { "type": "boolean" }
      }
    },
    "comparison": {
      "type": "object",
      "additionalProperties": false,
      "required": ["llvm_analysis_id", "llvm_semantic_digest", "llvm_classification", "relation", "explanation"],
      "properties": {
        "llvm_analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
        "llvm_semantic_digest": { "$ref": "#/$defs/sha256" },
        "llvm_classification": { "type": "string", "minLength": 1 },
        "relation": { "enum": ["agrees", "diverges", "not_comparable"] },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["function", "line", "llvm_report"],
      "properties": {
        "function": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "llvm_report": { "type": ["string", "null"] }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size", "media_type"],
      "properties": {
        "path": { "type": "string", "pattern": "^(inputs|gcc)/" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
