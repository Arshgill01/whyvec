{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whyvec.dev/schemas/fixture-manifest.schema.json",
  "title": "WhyVec compiler fixture manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "toolchain_profiles", "cases"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+$"
    },
    "toolchain_profiles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "frontend",
        "language",
        "toolchain_profile",
        "source",
        "selector",
        "expected_baseline"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]+$"
        },
        "frontend": {
          "enum": ["clang", "rustc"]
        },
        "language": {
          "enum": ["c", "cpp", "rust", "typescript"]
        },
        "toolchain_profile": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "pattern": "^cases/.+\\.(c|cc|cpp|rs)$"
        },
        "selector": {
          "type": "object",
          "additionalProperties": false,
          "required": ["function", "line"],
          "properties": {
            "function": { "type": "string", "minLength": 1 },
            "line": { "type": "integer", "minimum": 1 }
          }
        },
        "expected_baseline": {
          "enum": ["missed", "vectorized"]
        },
        "pipeline_fidelity": {
          "enum": ["exact", "equivalent_confirmed", "surrogate"]
        },
        "ir_parameters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "monolithic_counterfactuals": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "pattern": "^cases/.+\\.(c|cc|cpp|rs)$"
          }
        },
        "expected_successful_singletons": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "preferred_explanation_singleton": {
          "type": "string",
          "minLength": 1
        },
        "expected_obligation": {
          "type": "string",
          "minLength": 1
        },
        "expected_obligation_status": {
          "enum": ["derived", "declined"]
        },
        "expected_decline": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
        }
      }
    }
  }
}
