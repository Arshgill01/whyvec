{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "files_inspected", "alternatives", "files_changed", "commands", "validation", "evidence_language", "residual_risks"],
  "properties": {
    "summary": {"type": "string"},
    "files_inspected": {"type": "array", "items": {"type": "string"}},
    "alternatives": {"type": "array", "items": {"type": "object", "required": ["strategy", "decision", "reason"], "properties": {"strategy": {"type": "string"}, "decision": {"type": "string"}, "reason": {"type": "string"}}, "additionalProperties": false}},
    "files_changed": {"type": "array", "items": {"type": "string"}},
    "commands": {"type": "array", "items": {"type": "object", "required": ["command", "outcome"], "properties": {"command": {"type": "string"}, "outcome": {"type": "string"}}, "additionalProperties": false}},
    "validation": {"type": "array", "items": {"type": "string"}},
    "evidence_language": {"type": "array", "items": {"type": "string"}},
    "residual_risks": {"type": "array", "items": {"type": "string"}}
  }
}
