{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whyvec.dev/schemas/whyvec-obligation-report.schema.json",
  "title": "WhyVec obligation derivation report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "analysis_id", "query_kind", "adapter", "repository",
    "source", "source_digest", "optimization_analysis_id",
    "optimization_semantic_digest", "clang", "obligation", "decline", "replay",
    "semantic_digest", "artifacts", "artifact_path", "caveats"
  ],
  "properties": {
    "schema_version": { "const": "2.0.0-dev" },
    "analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
    "query_kind": { "const": "obligation_derivation" },
    "adapter": { "const": "clang_ast_affine_bound_v1" },
    "repository": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "source_digest": { "$ref": "#/$defs/sha256" },
    "optimization_analysis_id": { "type": "string", "pattern": "^wv_[a-f0-9]{24}$" },
    "optimization_semantic_digest": { "$ref": "#/$defs/sha256" },
    "clang": { "$ref": "#/$defs/tool" },
    "obligation": {
      "oneOf": [{ "$ref": "#/$defs/obligation" }, { "type": "null" }]
    },
    "decline": {
      "oneOf": [{ "$ref": "#/$defs/decline" }, { "type": "null" }]
    },
    "replay": { "$ref": "#/$defs/replay" },
    "semantic_digest": { "$ref": "#/$defs/sha256" },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/artifact" }
    },
    "artifact_path": { "type": "string", "minLength": 1 },
    "caveats": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "oneOf": [
    { "properties": { "obligation": { "$ref": "#/$defs/obligation" }, "decline": { "type": "null" } } },
    { "properties": { "obligation": { "type": "null" }, "decline": { "$ref": "#/$defs/decline" } } }
  ],
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["invocation_path", "resolved_path", "binary_digest", "version"],
      "properties": {
        "invocation_path": { "type": "string", "minLength": 1 },
        "resolved_path": { "type": "string", "minLength": 1 },
        "binary_digest": { "$ref": "#/$defs/sha256" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "entity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source_type", "byte_width", "signed"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "byte_width": { "type": "integer", "minimum": 1 },
        "signed": { "type": "boolean" }
      }
    },
    "induction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["variable", "source_type", "lower_bound", "upper_bound_parameter", "comparison", "step", "zero_trip_when_upper_at_most_lower"],
      "properties": {
        "variable": { "type": "string", "minLength": 1 },
        "source_type": { "type": "string", "minLength": 1 },
        "lower_bound": { "type": "integer" },
        "upper_bound_parameter": { "type": "string", "minLength": 1 },
        "comparison": { "const": "less_than" },
        "step": { "type": "integer", "minimum": 1 },
        "zero_trip_when_upper_at_most_lower": { "const": true }
      }
    },
    "write": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_parameter", "element_type", "element_bytes", "index_expression", "conservative_first_index", "conservative_last_index"],
      "properties": {
        "base_parameter": { "type": "string", "minLength": 1 },
        "element_type": { "type": "string", "minLength": 1 },
        "element_bytes": { "type": "integer", "minimum": 1 },
        "index_expression": { "type": "string", "minLength": 1 },
        "conservative_first_index": { "type": "string", "minLength": 1 },
        "conservative_last_index": { "type": "string", "minLength": 1 }
      }
    },
    "access_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "function", "loop_line", "bound_object", "induction", "writes", "calls_in_loop", "volatile_accesses", "atomic_accesses"],
      "properties": {
        "model": { "const": "clang_ast_affine_bound_v1" },
        "function": { "type": "string", "minLength": 1 },
        "loop_line": { "type": "integer", "minimum": 1 },
        "bound_object": { "$ref": "#/$defs/entity" },
        "induction": { "$ref": "#/$defs/induction" },
        "writes": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/write" } },
        "calls_in_loop": { "const": 0 },
        "volatile_accesses": { "const": 0 },
        "atomic_accesses": { "const": 0 }
      }
    },
    "guard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_policy", "capture", "checked_operations", "condition", "fast_path_requirement", "fallback_requirement"],
      "properties": {
        "target_policy": { "const": "flat_uintptr_x86_64" },
        "capture": { "type": "string", "minLength": 1 },
        "checked_operations": { "type": "array", "minItems": 3, "items": { "type": "string", "minLength": 1 } },
        "condition": { "type": "string", "minLength": 1 },
        "fast_path_requirement": { "type": "string", "minLength": 1 },
        "fallback_requirement": { "type": "string", "minLength": 1 }
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_strength", "family", "candidate_assumption", "predicate", "access_summary", "runtime_guard", "limitations"],
      "properties": {
        "evidence_strength": { "const": "derived_obligation" },
        "family": { "const": "bound_object_disjoint_from_modified_region" },
        "candidate_assumption": { "type": "string", "pattern": "^parameter\\.[a-zA-Z_][a-zA-Z0-9_]*\\.noalias$" },
        "predicate": { "type": "string", "minLength": 1 },
        "access_summary": { "$ref": "#/$defs/access_summary" },
        "runtime_guard": { "$ref": "#/$defs/guard" },
        "limitations": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    },
    "decline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "explanation"],
      "properties": {
        "code": { "type": "string", "pattern": "^obligation\\.[a-z0-9_]+$" },
        "explanation": { "type": "string", "minLength": 1 }
      }
    },
    "replay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["optimization_report"],
      "properties": { "optimization_report": { "type": "string", "minLength": 1 } }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size", "media_type"],
      "properties": {
        "path": { "type": "string", "pattern": "^(inputs|ast)/" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size": { "type": "integer", "minimum": 0 },
        "media_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
